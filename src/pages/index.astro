---
const company = {
  name: "마이너스베타스튜디오",
  representative: "강대종",
  bizNumber: "878-21-02478",
  mailOrderNumber: "제 2026-서울마포-1177 호",
  address: "서울특별시 마포구 만리재로10길 4 (공덕동)",
  category: "정보통신업 / 응용 소프트웨어 개발 및 공급업",
  email: "minusbetastudio@gmail.com",
  github: "github.com/ssamssae",
  worklog: "work.kangdaejong.com",
  newsletter: "https://daejongkang.substack.com",
};

const slogan = "오늘 하루, 조금 더 가볍게";
const intro = "마이너스베타스튜디오는 강대종이 혼자 꾸리는 작은 스튜디오예요. 누군가의 하루가 조금 더 가벼워지면 좋겠다는 마음으로 메모요·한줄일기 같은 Flutter 앱을 만들어요. 다섯 대의 기기가 밤낮으로 함께 돌아가는 AI 자동화 위에서, 매일 새로운 사이드 프로젝트도 조금씩 자라고 있어요.";

const services = [
  { title: "Flutter 앱 개발", desc: "iOS/Android 동시 출시 가능한 1인 풀스택 앱 빌드." },
  { title: "AI 자동화 시스템", desc: "5노드 멀티 디바이스 + Claude Code 운영, 자동화·파이프라인 설계." },
  { title: "사이드 프로젝트 인큐베이션", desc: "기록·일상·계산 분야 미니멀 도구 시리즈를 짓고 운영." },
];

const apps = [
  { name: "메모요", desc: "심플한 메모 앱. 정식 출시.", platforms: ["iOS", "Android"] },
  { name: "한줄일기", desc: "하루 한 줄로 기록하는 일기 앱.", platforms: ["iOS", "Android"] },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${company.name} — Flutter 앱 + AI 자동화 1인 스튜디오. 대표 ${company.representative}.`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Pretendard:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{company.name}</title>
  </head>
  <body>
    <main>
      <section class="hero">
        <div class="hero-mark">[<span class="accent-cyan">minus</span><span class="accent-magenta">beta</span>]</div>
        <h1>{company.name}</h1>
        <p class="slogan">{slogan}</p>
      </section>

      <section class="beta-banner">
        <div class="beta-tag">[ <span class="accent-cyan">beta</span> <span class="accent-magenta">testers</span> wanted ]</div>
        <h2>베타테스터 모집</h2>
        <p>마이너스베타스튜디오의 새 앱을 출시 전에 가장 먼저 써보실 분을 찾아요. 아래 ①그룹에 가입한 뒤 ②설치할 앱의 "테스터로 참여"를 누르면 Google Play에서 비공개 테스트 버전을 받을 수 있어요.</p>
        <a class="beta-cta" href="https://groups.google.com/g/minusbetastudio" target="_blank" rel="noopener">① 그룹 가입하고 베타테스터 되기 →</a>
        <div class="beta-optins">
          <div class="beta-optins-label">② 가입 후, 설치할 앱의 테스터로 참여하기</div>
          <div class="beta-optin-row">
            <a class="optin-btn" href="https://play.google.com/apps/testing/com.daejongkang.wordyo" target="_blank" rel="noopener">단어요 →</a>
            <a class="optin-btn" href="https://play.google.com/apps/testing/com.daejongkang.dutchpay" target="_blank" rel="noopener">더치페이 →</a>
          </div>
        </div>
      </section>

      <section class="block">
        <h2>회사 소개</h2>
        <p>{intro}</p>
      </section>

      <section class="block">
        <h2>사업 분야</h2>
        <ul class="services">
          {services.map((s) => (
            <li>
              <strong class="accent-cyan">{s.title}</strong>
              <span>{s.desc}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="block">
        <h2>앱 포트폴리오</h2>
        <div class="apps">
          {apps.map((a) => (
            <article class="app-card">
              <h3>{a.name}</h3>
              <p>{a.desc}</p>
              <div class="platforms">
                {a.platforms.map((p) => <span class="platform">{p}</span>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="block link-card-row">
        <a class="link-card" href={`https://${company.worklog}`}>
          <h3 class="accent-cyan">작업 일지</h3>
          <p>대표 강대종의 일별 작업·진행 중인 프로젝트·릴리즈 노트.</p>
          <span class="link-target">{company.worklog} →</span>
        </a>
        <a class="link-card" href={company.newsletter}>
          <h3 class="accent-magenta">뉴스레터</h3>
          <p>1인 스튜디오의 빌드·운영·실험 이야기.</p>
          <span class="link-target">Substack →</span>
        </a>
      </section>

      <section class="block">
        <h2>연락처</h2>
        <ul class="contact">
          <li><span class="label">Email</span><a href={`mailto:${company.email}`}>{company.email}</a></li>
          <li><span class="label">GitHub</span><a href={`https://${company.github}`}>{company.github}</a></li>
        </ul>
      </section>

      <footer>
        <div class="biz">
          <span>{company.name}</span>
          <span>대표 {company.representative}</span>
          <span>사업자등록번호 {company.bizNumber}</span>
          <span>통신판매업신고번호 {company.mailOrderNumber}</span>
          <span>{company.address}</span>
          <span>{company.category}</span>
        </div>
        <div class="copy">© 2026 {company.name}. All rights reserved.</div>
      </footer>
    </main>

    <style is:global>
      :root {
        --bg: #0a0a0a;
        --bg-elev: #131313;
        --fg: #f5f5f5;
        --fg-dim: #a0a0a0;
        --border: #1f1f1f;
        --cyan: #00e5ff;
        --magenta: #ff00aa;
        --mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
        --sans: "Pretendard", -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", sans-serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { background: var(--bg); color: var(--fg); font-family: var(--sans); line-height: 1.65; }
      main { max-width: 760px; margin: 0 auto; padding: 96px 24px 64px; }
      a { color: var(--cyan); text-decoration: none; }
      a:hover { color: var(--magenta); }
      h1, h2, h3 { font-weight: 700; letter-spacing: -0.01em; }
      .accent-cyan { color: var(--cyan); }
      .accent-magenta { color: var(--magenta); }

      .hero { margin-bottom: 96px; }
      .hero-mark { font-family: var(--mono); font-size: 14px; color: var(--fg-dim); margin-bottom: 24px; }
      .hero h1 { font-size: 42px; margin-bottom: 16px; }
      .hero .slogan { font-size: 18px; color: var(--fg-dim); }

      .beta-banner { margin-bottom: 64px; background: linear-gradient(135deg, rgba(0,229,255,0.07), rgba(255,0,170,0.07)); border: 1px solid var(--border); border-radius: 12px; padding: 32px; }
      .beta-banner .beta-tag { font-family: var(--mono); font-size: 13px; color: var(--fg-dim); margin-bottom: 14px; }
      .beta-banner h2 { font-size: 24px; margin-bottom: 12px; color: var(--fg); }
      .beta-banner p { color: var(--fg-dim); font-size: 15px; margin-bottom: 22px; }
      .beta-cta { display: inline-block; font-family: var(--mono); font-size: 14px; font-weight: 600; padding: 12px 20px; border: 1px solid var(--cyan); border-radius: 8px; color: var(--cyan); }
      .beta-cta:hover { background: var(--cyan); color: var(--bg); }
      .beta-optins { margin-top: 24px; padding-top: 22px; border-top: 1px solid var(--border); }
      .beta-optins-label { font-family: var(--mono); font-size: 13px; color: var(--fg-dim); margin-bottom: 14px; }
      .beta-optin-row { display: flex; flex-wrap: wrap; gap: 10px; }
      .optin-btn { display: inline-block; font-family: var(--mono); font-size: 13px; font-weight: 600; padding: 10px 16px; border: 1px solid var(--magenta); border-radius: 8px; color: var(--magenta); }
      .optin-btn:hover { background: var(--magenta); color: var(--bg); }

      .block { margin-bottom: 64px; }
      .block h2 { font-size: 14px; text-transform: uppercase; letter-spacing: 0.15em; color: var(--fg-dim); margin-bottom: 24px; font-family: var(--mono); font-weight: 600; }

      .services { list-style: none; display: grid; gap: 16px; }
      .services li { display: grid; grid-template-columns: 200px 1fr; gap: 16px; padding: 16px 0; border-top: 1px solid var(--border); }
      .services li:last-child { border-bottom: 1px solid var(--border); }
      .services strong { font-size: 16px; }
      .services span { color: var(--fg-dim); }

      .apps { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
      .app-card { background: var(--bg-elev); border: 1px solid var(--border); padding: 24px; border-radius: 8px; }
      .app-card h3 { font-size: 20px; margin-bottom: 8px; }
      .app-card p { color: var(--fg-dim); font-size: 14px; margin-bottom: 16px; }
      .platforms { display: flex; gap: 8px; }
      .platform { font-family: var(--mono); font-size: 11px; padding: 4px 8px; border: 1px solid var(--border); border-radius: 4px; color: var(--fg-dim); }

      .link-card-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .link-card { display: block; background: var(--bg-elev); border: 1px solid var(--border); padding: 24px; border-radius: 8px; color: var(--fg); border-bottom: none; }
      .link-card:hover { border-color: var(--cyan); border-bottom: 1px solid var(--cyan); }
      .link-card h3 { font-size: 18px; margin-bottom: 8px; }
      .link-card p { color: var(--fg-dim); font-size: 14px; margin-bottom: 16px; }
      .link-target { font-family: var(--mono); font-size: 12px; color: var(--fg-dim); }

      .contact { list-style: none; display: grid; gap: 8px; }
      .contact li { display: grid; grid-template-columns: 100px 1fr; padding: 12px 0; border-top: 1px solid var(--border); align-items: center; }
      .contact li:last-child { border-bottom: 1px solid var(--border); }
      .contact .label { font-family: var(--mono); font-size: 12px; color: var(--fg-dim); text-transform: uppercase; letter-spacing: 0.1em; }

      footer { margin-top: 96px; padding-top: 32px; border-top: 1px solid var(--border); font-family: var(--mono); font-size: 12px; color: var(--fg-dim); }
      footer .biz { display: flex; flex-wrap: wrap; gap: 12px; row-gap: 6px; margin-bottom: 16px; }
      footer .biz span:not(:last-child)::after { content: "  ·"; color: var(--border); margin-left: 12px; }
      footer .copy { font-size: 11px; opacity: 0.7; }

      @media (max-width: 640px) {
        main { padding: 64px 20px 48px; }
        .hero h1 { font-size: 32px; }
        .services li { grid-template-columns: 1fr; gap: 4px; }
        .apps { grid-template-columns: 1fr; }
        .link-card-row { grid-template-columns: 1fr; }
        .contact li { grid-template-columns: 80px 1fr; }
      }
    </style>
  </body>
</html>
