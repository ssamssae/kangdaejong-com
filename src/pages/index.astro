---
const company = {
  name: "마이너스베타스튜디오",
  representative: "강대종",
  bizNumber: "878-21-02478",
  mailOrderNumber: "제 2026-서울마포-1177 호",
  address: "서울특별시 마포구 만리재로10길 4 (공덕동)",
  category: "정보통신업 / 응용 소프트웨어 개발 및 공급업",
  email: "minusbetastudio@gmail.com",
  github: "github.com/ssamssae",
  worklog: "work.kangdaejong.com",
  newsletter: "https://daejongkang.substack.com",
};

const slogan = "Tools Worth Keeping.";
const sloganKo = "덜어내서, 오래 남을 도구를 만듭니다.";
const intro = "마이너스베타스튜디오는 강대종이 혼자 꾸리는 작은 스튜디오예요. 누군가의 하루가 조금 더 가벼워지면 좋겠다는 마음으로 메모요·한줄일기 같은 앱과 작은 웹 도구를 만들고 운영합니다. 필요할 때 AI 자동화와 여러 작업 노드를 활용해 반복 작업을 줄이고, 출시한 제품을 꾸준히 다듬어갑니다.";

const services = [
  { title: "Flutter 앱 개발", desc: "iOS/Android 동시 출시 가능한 1인 풀스택 앱 빌드.", accent: "accent-cyan" },
  { title: "웹 서비스 · SaaS", desc: "AI 사주 작명 ‘첫이름’ 같은 유료 웹 서비스를 직접 기획·개발 — 첫 서비스 출시 준비 중.", accent: "accent-magenta" },
];

const apps = [
  { name: "메모요", desc: "심플한 메모 앱. 정식 출시.", accent: "cyan", platforms: [
    { label: "iOS", url: "https://apps.apple.com/kr/app/id6762068073" },
    { label: "Android", url: "https://play.google.com/store/apps/details?id=com.daejongkang.simple_memo_app" },
  ] },
  { name: "한줄일기", desc: "하루 한 줄로 기록하는 일기 앱.", accent: "magenta", platforms: [
    { label: "iOS", url: "https://apps.apple.com/kr/app/id6764308678" },
    { label: "Android", url: "https://play.google.com/store/apps/details?id=com.daejongkang.hanjul" },
  ] },
];

const bridges = [
  {
    name: "Codex Telegram Bridge",
    status: "PUBLIC · v0.3.23",
    desc: "Codex CLI REPL을 텔레그램에서 제어하는 공개 브릿지. 텍스트·이미지·영상·음성·파일 입력과 진행보고, reasoning mirror, typing recovery를 지원합니다.",
    repo: "https://github.com/ssamssae/codex-telegram-bridge",
    release: "https://github.com/ssamssae/codex-telegram-bridge/releases/tag/v0.3.23",
    accent: "cyan",
  },
  {
    name: "Claude Telegram Bridge",
    status: "PUBLIC · v0.1.0",
    desc: "Claude Code live tmux 세션을 텔레그램에 연결하는 공개 브릿지. claude -p 없이 세션 주입, transcript 추출, 미디어 local_path 전달로 동작합니다.",
    repo: "https://github.com/ssamssae/claude-telegram-bridge",
    release: "https://github.com/ssamssae/claude-telegram-bridge/releases/tag/v0.1.0",
    accent: "magenta",
  },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${company.name} — Flutter 앱과 작은 웹 도구를 만드는 1인 스튜디오. 대표 ${company.representative}.`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Pretendard:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{company.name}</title>
    <script is:inline src="/mb-components.js" defer></script>
  </head>
  <body>
    <mb-header active="home"></mb-header>
    <main>
      <section class="hero" id="top">
        <img class="hero-logo" src="/minusbeta-badge.svg" alt="마이너스베타스튜디오 로고" width="88" height="88" />
        <h1>{company.name}</h1>
        <p class="slogan-ko">{sloganKo}</p>
      </section>

      <section class="block" id="open-tools">
        <h2>공개 자동화 도구</h2>
        <div class="bridge-intro">
          <strong>Telegram Bridges</strong>
          <span>마이너스베타스튜디오 5노드 자동화 운영에서 실제로 쓰는 Codex·Claude 전용 브릿지.</span>
        </div>
        <div class="bridge-grid">
          {bridges.map((b) => (
            <article class={`bridge-card bridge-card--${b.accent}`}>
              <div class="bridge-card-top">
                <h3>{b.name}</h3>
                <span>{b.status}</span>
              </div>
              <p>{b.desc}</p>
              <div class="bridge-links">
                <a href={b.repo} target="_blank" rel="noopener">GitHub →</a>
                <a href={b.release} target="_blank" rel="noopener">Release →</a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="brand-statement" aria-label="브랜드 슬로건">
        <span class="statement-kicker">Minus Beta Studio</span>
        <strong>{slogan}</strong>
        <p>사람들이 지우지 않고 계속 두는 작은 앱과 도구를 만듭니다.</p>
      </section>

      <section class="block" id="about">
        <h2>회사 소개</h2>
        <p>{intro}</p>
      </section>

      <section class="block" id="business">
        <h2>사업 분야</h2>
        <ul class="services">
          {services.map((s) => (
            <li>
              <strong class={s.accent}>{s.title}</strong>
              <span>{s.desc}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="block" id="portfolio">
        <h2>앱 포트폴리오</h2>
        <div class="apps">
          {apps.map((a) => (
            <article class={`app-card tone-${a.accent}`}>
              <h3>{a.name}</h3>
              <p>{a.desc}</p>
              <div class="platforms">
                {a.platforms.map((p) => <a class="platform" href={p.url} target="_blank" rel="noopener">{p.label} →</a>)}
              </div>
            </article>
          ))}
        </div>
        <a class="apps-all" href="https://work.kangdaejong.com/products/">전체 앱 보기 →</a>
      </section>

      <section class="block link-card-row">
        <a class="link-card tone-cyan" href={`https://${company.worklog}`}>
          <h3 class="accent-cyan">작업 일지</h3>
          <p>대표 강대종의 일별 작업·진행 중인 프로젝트·릴리즈 노트.</p>
          <span class="link-target">{company.worklog} →</span>
        </a>
        <a class="link-card tone-magenta" href={company.newsletter}>
          <h3 class="accent-magenta">뉴스레터</h3>
          <p>1인 스튜디오의 빌드·운영·실험 이야기.</p>
          <span class="link-target">Substack →</span>
        </a>
      </section>

      <section class="block" id="contact">
        <h2>연락처</h2>
        <ul class="contact">
          <li><span class="label">Email</span><a href={`mailto:${company.email}`}>{company.email}</a></li>
          <li><span class="label">GitHub</span><a href={`https://${company.github}`}>{company.github}</a></li>
        </ul>
      </section>

    </main>
    <mb-footer></mb-footer>

    <style is:global>
      :root {
        --bg: #0a0a0a;
        --bg-elev: #131313;
        --fg: #f5f5f5;
        --fg-dim: #a0a0a0;
        --border: #1f1f1f;
        --cyan: #00e5ff;
        --magenta: #ff00aa;
        --mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
        --sans: "Pretendard", -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", sans-serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      html, body { background: var(--bg); color: var(--fg); font-family: var(--sans); line-height: 1.65; }
      [id] { scroll-margin-top: 72px; }

      main { max-width: 760px; margin: 0 auto; padding: 48px 24px 64px; }
      a { color: var(--cyan); text-decoration: none; }
      a:hover { color: var(--magenta); }
      h1, h2, h3 { font-weight: 700; letter-spacing: -0.01em; }
      .accent-cyan { color: var(--cyan); }
      .accent-magenta { color: var(--magenta); }

      .hero { margin-bottom: 40px; }
      .hero-logo { display: block; border-radius: 20px; margin-bottom: 24px; }
      .hero h1 { font-size: 42px; margin-bottom: 20px; }
      .hero .slogan-ko { font-size: 18px; color: var(--fg-dim); }

      .brand-statement {
        margin-bottom: 80px;
        padding: 28px 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      .statement-kicker {
        display: block;
        margin-bottom: 10px;
        font-family: var(--mono);
        font-size: 12px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--cyan);
      }
      .brand-statement strong {
        display: block;
        font-family: var(--mono);
        font-size: clamp(24px, 5vw, 42px);
        line-height: 1.1;
        margin-bottom: 12px;
      }
      .brand-statement p { color: var(--fg-dim); font-size: 16px; }

      .block { margin-bottom: 64px; }
      .block h2 { font-size: 14px; text-transform: uppercase; letter-spacing: 0.15em; color: var(--fg-dim); margin-bottom: 24px; font-family: var(--mono); font-weight: 600; }

      .bridge-intro { display: grid; grid-template-columns: 200px 1fr; gap: 16px; padding: 16px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); margin-bottom: 16px; }
      .bridge-intro strong { color: var(--cyan); font-size: 16px; }
      .bridge-intro span { color: var(--fg-dim); }
      .bridge-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
      .bridge-card { background: var(--bg-elev); border: 1px solid var(--border); border-radius: 8px; padding: 24px; transition: border-color 0.15s; }
      .bridge-card--cyan:hover { border-color: var(--cyan); }
      .bridge-card--magenta:hover { border-color: var(--magenta); }
      .bridge-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 12px; }
      .bridge-card h3 { font-size: 18px; line-height: 1.35; color: var(--cyan); }
      .bridge-card--magenta h3 { color: var(--magenta); }
      .bridge-card-top span { flex: 0 0 auto; font-family: var(--mono); font-size: 10px; color: var(--fg-dim); line-height: 1.35; padding-top: 3px; }
      .bridge-card p { color: var(--fg-dim); font-size: 14px; margin-bottom: 16px; }
      .bridge-links { display: flex; flex-wrap: wrap; gap: 12px; font-family: var(--mono); font-size: 12px; }
      .bridge-links a { color: var(--fg-dim); }
      .bridge-card--cyan .bridge-links a:hover { color: var(--cyan); }
      .bridge-card--magenta .bridge-links a:hover { color: var(--magenta); }

      .services { list-style: none; display: grid; gap: 16px; }
      .services li { display: grid; grid-template-columns: 200px 1fr; gap: 16px; padding: 16px 0; border-top: 1px solid var(--border); }
      .services li:last-child { border-bottom: 1px solid var(--border); }
      .services strong { font-size: 16px; }
      .services span { color: var(--fg-dim); }

      .apps { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
      .app-card { background: var(--bg-elev); border: 1px solid var(--border); padding: 24px; border-radius: 8px; transition: border-color 0.15s; }
      .app-card.tone-cyan:hover { border-color: var(--cyan); }
      .app-card.tone-magenta:hover { border-color: var(--magenta); }
      .app-card h3 { font-size: 20px; margin-bottom: 8px; }
      .app-card.tone-cyan h3 { color: var(--cyan); }
      .app-card.tone-magenta h3 { color: var(--magenta); }
      .app-card p { color: var(--fg-dim); font-size: 14px; margin-bottom: 16px; }
      .platforms { display: flex; gap: 8px; }
      .platform { font-family: var(--mono); font-size: 11px; padding: 4px 8px; border: 1px solid var(--border); border-radius: 4px; color: var(--fg-dim); transition: border-color 0.15s, color 0.15s; }
      .tone-cyan .platform:hover { border-color: var(--cyan); color: var(--cyan); }
      .tone-magenta .platform:hover { border-color: var(--magenta); color: var(--magenta); }
      .apps-all { display: inline-block; margin-top: 16px; font-family: var(--mono); font-size: 13px; color: var(--fg-dim); }
      .apps-all:hover { color: var(--cyan); }

      .link-card-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .link-card { display: block; background: var(--bg-elev); border: 1px solid var(--border); padding: 24px; border-radius: 8px; color: var(--fg); border-bottom: none; }
      .link-card.tone-cyan:hover { border-color: var(--cyan); border-bottom: 1px solid var(--cyan); }
      .link-card.tone-magenta:hover { border-color: var(--magenta); border-bottom: 1px solid var(--magenta); }
      .link-card h3 { font-size: 18px; margin-bottom: 8px; }
      .link-card p { color: var(--fg-dim); font-size: 14px; margin-bottom: 16px; }
      .link-target { font-family: var(--mono); font-size: 12px; color: var(--fg-dim); }

      .contact { list-style: none; display: grid; gap: 8px; }
      .contact li { display: grid; grid-template-columns: 100px 1fr; padding: 12px 0; border-top: 1px solid var(--border); align-items: center; }
      .contact li:last-child { border-bottom: 1px solid var(--border); }
      .contact .label { font-family: var(--mono); font-size: 12px; color: var(--fg-dim); text-transform: uppercase; letter-spacing: 0.1em; }

      @media (max-width: 640px) {
        main { padding: 32px 20px 48px; }
        .hero-logo { width: 64px; height: 64px; }
        .hero h1 { font-size: 32px; }
        .hero .slogan-ko { font-size: 16px; }
        .brand-statement { margin-bottom: 56px; padding: 22px 0; }
        .bridge-intro { grid-template-columns: 1fr; gap: 4px; }
        .bridge-grid { grid-template-columns: 1fr; }
        .bridge-card-top { display: block; }
        .bridge-card-top span { display: block; margin-top: 5px; }
        .services li { grid-template-columns: 1fr; gap: 4px; }
        .apps { grid-template-columns: 1fr; }
        .link-card-row { grid-template-columns: 1fr; }
        .contact li { grid-template-columns: 80px 1fr; }
      }
    </style>
  </body>
</html>
